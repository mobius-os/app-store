{
  "id": "store",
  "name": "App Store",
  "version": "1.10.6",
  "description": "Discover, install, and update M\u00f6bius apps.",
  "author": "mobius-os",
  "license": "MIT",
  "homepage": "https://github.com/mobius-os/app-store",
  "icon": "icon.png",
  "entry": "index.jsx",
  "offline_capable": false,
  "offline": {
    "reads": false,
    "writes": "none",
