      "react",
      "react-dom"
    ],
    "esm_deps": []
  },
  "source_files": [
    "constants.js",
    "theme.js",
    "domain.js",
    "storage.js",
    "api.js",
    "ui/IconBox.jsx",
    "ui/PermissionRow.jsx",
    "ui/UninstallConfirmModal.jsx",
    "ui/CatalogCard.jsx",
    "ui/CatalogFilters.jsx",
    "ui/CatalogList.jsx",
    "ui/CatalogSkeleton.jsx",
    "ui/FromUrlTab.jsx",
    "ui/DetailView.jsx",
    "ui/SelfUpdateBanner.jsx"
  ]
}
