{
  "id": "store",
  "name": "App Store",
  "version": "1.13.2",
  "description": "Discover, install, and update M\u00f6bius apps.",
  "author": "mobius-os",
  "license": "MIT",
  "homepage": "https://github.com/mobius-os/app-store",
  "icon": "icon.png",
  "entry": "index.jsx",
  "offline_capable": true,
  "offline": {
    "reads": true,
    "writes": "none",
    "execution": "partial",
    "reads_detail": "The bundled catalog and validated manifest snapshots remain browsable offline. Installed-state refresh, installs, updates, and URL imports require a connection and stay disabled when installed state cannot be verified."
  },
  "permissions": {
    "cross_app_access": "none",
    "share_with_apps": "none",
    "manage_apps": true
  },
  "runtime": {
    "imports": [
      "react",
      "react-dom"
    ],
    "esm_deps": []
  },
  "source_files": [
    "constants.js",
    "theme.js",
    "domain.js",
    "update-review.js",
    "storage.js",
    "api.js",
    "manifest-snapshots.js",
    "ui/IconBox.jsx",
    "ui/PermissionRow.jsx",
    "ui/CapabilityContract.jsx",
    "ui/UninstallConfirmModal.jsx",
    "ui/CatalogCard.jsx",
    "ui/CatalogFilters.jsx",
    "ui/CatalogList.jsx",
    "ui/CatalogSkeleton.jsx",
    "ui/FromUrlTab.jsx",
    "ui/DetailView.jsx",
    "ui/UpdateReviewModal.jsx",
    "ui/SelfUpdateBanner.jsx"
  ]
}
